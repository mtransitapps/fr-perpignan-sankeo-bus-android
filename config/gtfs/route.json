  "trip_id_cleanup_regex": "\\d{4}-\\w{3}-|(lv|-d|-s|-w)|-\\d{2}(-|$)",
  "trip_headsign_cleaners": [
    {
      "regex": "^(aller|retour)$",
      "ignore_case": true
    },
    {
      "regex": "^[l]\\w+ - ",
      "ignore_case": true,
      "regex_comment": "Start with L RSN"
    },
    {
      "regex": "AM",
      "is_word": true,
      "ignore_case": true,
      "replacement": "Matin"
    },
    {
      "regex": "PM",
      "is_word": true,
      "ignore_case": true,
      "replacement": "Après-Midi"
    },
    {
      "regex": "corneilla\\s*-\\s*la\\s*-\\s*rivière",
      "ignore_case": true,
      "replacement": "Corneilla-la-Rivière"
    },
    {
      "regex": "pézilla\\s*-\\s*la\\s*-\\s*rivière",
      "ignore_case": true,
      "replacement": "Pézilla-la-Rivière"
    },
    {
      "regex": "Assiscl",
      "ignore_case": true,
      "is_word": true,
      "replacement": "Assiscle"
    }
  ],
  "use_stop_id_hash_code": true
}
